generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id            String              @id @default(uuid())
  name          String
  slug          String              @unique
  logo          String?
  status        String              @default("PENDING")
  planId        String?
  features      Json?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  categories    Category[]
  customers     Customer[]
  deals         Deal[]
  departments   Department[]
  inventoryDocs InventoryDocument[]
  ledgers       Ledger[]
  orders        Order[]
  payments      Payment[]
  pricingRules  PricingRule[]
  products      Product[]
  sales         Sale[]
  salesOrders   SalesOrder[]
  suppliers     Supplier[]
  plan          Plan?               @relation(fields: [planId], references: [id])
  users         UserTenant[]
  warehouses    Warehouse[]
}

model Plan {
  id           String   @id @default(uuid())
  name         String   @unique
  price        Float
  billingCycle String   @default("MONTHLY")
  features     Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenants      Tenant[]
}

model UserTenant {
  userId   String
  tenantId String
  roleId   String
  isActive Boolean @default(true)
  role     Role    @relation(fields: [roleId], references: [id])
  tenant   Tenant  @relation(fields: [tenantId], references: [id])
  user     User    @relation(fields: [userId], references: [id])

  @@id([userId, tenantId])
}

model Role {
  id          String       @id @default(uuid())
  name        String
  code        String       @unique
  userTenants UserTenant[]
  permissions Permission[] @relation("PermissionToRole")
}

model Permission {
  id       String @id @default(uuid())
  code     String @unique
  name     String
  category String
  roles    Role[] @relation("PermissionToRole")
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  password       String
  firstName      String
  lastName       String
  role           String       @default("STAFF")
  isActive       Boolean      @default(true)
  isDeleted      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deals          Deal[]
  employee       Employee?
  approvedOrders Order[]      @relation("OrderApprover")
  tenants        UserTenant[]
}

model Category {
  id          String    @id @default(uuid())
  name        String
  description String?
  tenantId    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  products    Product[]

  @@unique([tenantId, name])
}

model Product {
  id                String                  @id @default(uuid())
  sku               String
  name              String
  description       String?
  price             Float
  costPrice         Float
  stockQuantity     Int                     @default(0)
  unit              String                  @default("pcs")
  isBatchTracked    Boolean                 @default(false)
  lowStockThreshold Int                     @default(10)
  reorderPoint      Int                     @default(10)
  reorderQuantity   Int                     @default(50)
  leadTimeDays      Int                     @default(7)
  avgDailySales     Float                   @default(0.0)
  categoryId        String
  tenantId          String
  isDeleted         Boolean                 @default(false)
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  dealItems         DealItem[]
  receiptItems      GoodsReceiptItem[]
  inventoryItems    InventoryDocumentItem[]
  orderItems        OrderItem[]
  pricingRules      PricingRule[]
  category          Category                @relation(fields: [categoryId], references: [id])
  tenant            Tenant                  @relation(fields: [tenantId], references: [id])
  saleItems         SaleItem[]
  salesOrderItems   SalesOrderItem[]
  stocks            Stock[]

  @@unique([tenantId, sku])
}

model Warehouse {
  id              String              @id @default(uuid())
  name            String
  location        String
  isDefault       Boolean             @default(false)
  tenantId        String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  goodsReceipts   GoodsReceipt[]
  sourceDocuments InventoryDocument[] @relation("SourceWarehouse")
  targetDocuments InventoryDocument[] @relation("TargetWarehouse")
  stocks          Stock[]
  tenant          Tenant              @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, name])
}

model Stock {
  id          String    @id @default(uuid())
  quantity    Int       @default(0)
  reserved    Int       @default(0)
  batchNumber String    @default("GENERAL")
  expiryDate  DateTime?
  warehouseId String
  productId   String
  updatedAt   DateTime  @updatedAt
  product     Product   @relation(fields: [productId], references: [id])
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([warehouseId, productId, batchNumber])
}

model Supplier {
  id           String   @id @default(uuid())
  name         String
  contact      String?
  email        String
  address      String?
  status       String   @default("ACTIVE")
  rating       Float    @default(5.0)
  paymentTerms String?
  taxId        String?
  tenantId     String
  isDeleted    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orders       Order[]
  tenant       Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, email])
}

model Order {
  id                   String         @id @default(uuid())
  orderNumber          String
  status               String         @default("DRAFT")
  approvalStatus       String         @default("PENDING")
  approvedById         String?
  totalAmount          Float
  taxAmount            Float          @default(0.0)
  trackingNumber       String?
  shippingCarrier      String?
  shippedAt            DateTime?
  expectedDeliveryDate DateTime?
  supplierId           String
  tenantId             String
  isDeleted            Boolean        @default(false)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  goodsReceipts        GoodsReceipt[]
  approvedBy           User?          @relation("OrderApprover", fields: [approvedById], references: [id])
  supplier             Supplier       @relation(fields: [supplierId], references: [id])
  tenant               Tenant         @relation(fields: [tenantId], references: [id])
  items                OrderItem[]

  @@unique([tenantId, orderNumber])
}

model OrderItem {
  id               String  @id @default(uuid())
  quantity         Int
  receivedQuantity Int     @default(0)
  unitPrice        Float
  orderId          String
  productId        String
  order            Order   @relation(fields: [orderId], references: [id])
  product          Product @relation(fields: [productId], references: [id])
}

model GoodsReceipt {
  id           String             @id @default(uuid())
  grnNumber    String
  orderId      String
  warehouseId  String
  receivedDate DateTime           @default(now())
  notes        String?
  order        Order              @relation(fields: [orderId], references: [id])
  warehouse    Warehouse          @relation(fields: [warehouseId], references: [id])
  items        GoodsReceiptItem[]

  @@unique([orderId, grnNumber])
}

model GoodsReceiptItem {
  id             String       @id @default(uuid())
  quantity       Int
  batchNumber    String?
  expiryDate     DateTime?
  goodsReceiptId String
  productId      String
  goodsReceipt   GoodsReceipt @relation(fields: [goodsReceiptId], references: [id])
  product        Product      @relation(fields: [productId], references: [id])
}

model InventoryDocument {
  id                String                  @id @default(uuid())
  type              String
  reference         String?
  status            String                  @default("DRAFT")
  sourceWarehouseId String?
  targetWarehouseId String?
  tenantId          String
  performedBy       String?
  notes             String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  sourceWarehouse   Warehouse?              @relation("SourceWarehouse", fields: [sourceWarehouseId], references: [id])
  targetWarehouse   Warehouse?              @relation("TargetWarehouse", fields: [targetWarehouseId], references: [id])
  tenant            Tenant                  @relation(fields: [tenantId], references: [id])
  items             InventoryDocumentItem[]
}

model InventoryDocumentItem {
  id         String            @id @default(uuid())
  quantity   Int
  documentId String
  productId  String
  document   InventoryDocument @relation(fields: [documentId], references: [id])
  product    Product           @relation(fields: [productId], references: [id])
}

model Deal {
  id                String       @id @default(uuid())
  title             String
  stage             String       @default("NEW")
  value             Float        @default(0.0)
  customerId        String?
  tenantId          String
  assignedToId      String?
  probability       Int          @default(10)
  expectedCloseDate DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  activities        Activity[]
  assignedTo        User?        @relation(fields: [assignedToId], references: [id])
  customer          Customer?    @relation(fields: [customerId], references: [id])
  tenant            Tenant       @relation(fields: [tenantId], references: [id])
  items             DealItem[]
  salesOrders       SalesOrder[]
}

model Activity {
  id        String   @id @default(uuid())
  type      String
  subject   String
  content   String?
  dealId    String
  createdAt DateTime @default(now())
  deal      Deal     @relation(fields: [dealId], references: [id])
}

model DealItem {
  id        String  @id @default(uuid())
  quantity  Int
  price     Float
  dealId    String
  productId String
  deal      Deal    @relation(fields: [dealId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

model SalesOrder {
  id          String           @id @default(uuid())
  orderNumber String
  status      String           @default("DRAFT")
  dealId      String?
  customerId  String
  tenantId    String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  customer    Customer         @relation(fields: [customerId], references: [id])
  deal        Deal?            @relation(fields: [dealId], references: [id])
  tenant      Tenant           @relation(fields: [tenantId], references: [id])
  items       SalesOrderItem[]

  @@unique([tenantId, orderNumber])
}

model SalesOrderItem {
  id           String     @id @default(uuid())
  quantity     Int
  reserved     Int        @default(0)
  salesOrderId String
  productId    String
  product      Product    @relation(fields: [productId], references: [id])
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id])
}

model Customer {
  id          String       @id @default(uuid())
  name        String
  email       String?
  phone       String?
  address     String?
  city        String?
  zipCode     String?
  tenantId    String
  isDeleted   Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  deals       Deal[]
  sales       Sale[]
  salesOrders SalesOrder[]
}

model Sale {
  id                String     @id @default(uuid())
  invoiceNo         String
  totalAmount       Float
  taxAmount         Float
  discountAmount    Float      @default(0.0)
  isHomeDelivery    Boolean    @default(false)
  deliveryAddress   String?
  deliveryCity      String?
  estimatedDelivery DateTime?
  team              String     @default("SALES")
  status            String     @default("PENDING")
  trackingNumber    String?
  shippingCarrier   String?
  shippedAt         DateTime?
  customerId        String?
  tenantId          String
  isDeleted         Boolean    @default(false)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  payment           Payment?
  customer          Customer?  @relation(fields: [customerId], references: [id])
  tenant            Tenant     @relation(fields: [tenantId], references: [id])
  items             SaleItem[]

  @@unique([tenantId, invoiceNo])
}

model SaleItem {
  id        String  @id @default(uuid())
  quantity  Int
  unitPrice Float
  saleId    String
  productId String
  product   Product @relation(fields: [productId], references: [id])
  sale      Sale    @relation(fields: [saleId], references: [id])
}

model Payment {
  id            String   @id @default(uuid())
  amount        Float
  method        String   @default("CASH")
  type          String   @default("RECEIVABLE")
  transactionId String?  @unique
  saleId        String?  @unique
  tenantId      String
  createdAt     DateTime @default(now())
  sale          Sale?    @relation(fields: [saleId], references: [id])
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
}

model Ledger {
  id          String   @id @default(uuid())
  title       String
  type        String
  amount      Float
  category    String   @default("GENERAL")
  description String?
  tenantId    String
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
}

model Department {
  id        String     @id @default(uuid())
  name      String
  tenantId  String
  isDeleted Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  employees Employee[]

  @@unique([tenantId, name])
}

model Employee {
  id                  String       @id @default(uuid())
  userId              String?      @unique
  employeeId          String       @unique
  firstName           String
  lastName            String
  designation         String
  joiningDate         DateTime
  salary              Float
  performanceRating   Int?
  incentivePercentage Float        @default(0.0)
  departmentId        String
  isDeleted           Boolean      @default(false)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  attendances         Attendance[]
  department          Department   @relation(fields: [departmentId], references: [id])
  user                User?        @relation(fields: [userId], references: [id])
  payrolls            Payroll[]
}

model PricingRule {
  id              String   @id @default(uuid())
  name            String
  minQuantity     Int
  discountPercent Float
  productId       String
  tenantId        String
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  product         Product  @relation(fields: [productId], references: [id])
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
}

model Attendance {
  id            String    @id @default(uuid())
  date          DateTime  @default(now())
  status        String
  checkIn       DateTime?
  checkOut      DateTime?
  overtimeHours Float     @default(0.0)
  employeeId    String
  employee      Employee  @relation(fields: [employeeId], references: [id])
}

model Payroll {
  id             String   @id @default(uuid())
  amount         Float
  incentive      Float    @default(0.0)
  overtimeAmount Float    @default(0.0)
  totalPayout    Float
  paymentDate    DateTime @default(now())
  month          String
  status         String   @default("PAID")
  employeeId     String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  employee       Employee @relation(fields: [employeeId], references: [id])
}
