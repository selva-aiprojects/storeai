generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Auth & User Management ---

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  firstName     String
  lastName      String
  role          String    @default("STAFF")
  isActive      Boolean   @default(true)
  isDeleted     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  employee      Employee?
  deals         Deal[]
  approvedOrders Order[] @relation("OrderApprover")
}

// --- Product Management ---

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id            String         @id @default(uuid())
  sku           String         @unique
  name          String
  description   String?
  price         Float
  costPrice     Float
  stockQuantity Int            @default(0)
  unit          String         @default("pcs")
  
  // Advanced Features
  isBatchTracked   Boolean    @default(false)
  lowStockThreshold Int       @default(10)
  reorderPoint     Int        @default(10)
  reorderQuantity  Int        @default(50)
  leadTimeDays     Int        @default(7)
  avgDailySales    Float      @default(0.0)
  
  categoryId    String
  category      Category       @relation(fields: [categoryId], references: [id])
  isDeleted     Boolean        @default(false)
  
  pricingRules  PricingRule[]
  orderItems    OrderItem[]
  saleItems     SaleItem[]
  stocks        Stock[]
  inventoryItems InventoryDocumentItem[]
  dealItems     DealItem[]
  salesOrderItems SalesOrderItem[]
  receiptItems  GoodsReceiptItem[]
  
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Warehouse {
  id         String   @id @default(uuid())
  name       String   @unique
  location   String
  isDefault  Boolean  @default(false)
  stocks     Stock[]
  
  sourceDocuments InventoryDocument[] @relation("SourceWarehouse")
  targetDocuments InventoryDocument[] @relation("TargetWarehouse")
  goodsReceipts   GoodsReceipt[]
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Stock {
  id           String    @id @default(uuid())
  quantity     Int       @default(0)
  reserved     Int       @default(0)
  
  batchNumber  String    @default("GENERAL")
  expiryDate   DateTime? 
  
  warehouseId  String
  warehouse    Warehouse @relation(fields: [warehouseId], references: [id])
  
  productId    String
  product      Product   @relation(fields: [productId], references: [id])

  updatedAt    DateTime  @updatedAt
  
  @@unique([warehouseId, productId, batchNumber])
}

// --- Order Management ---

model Supplier {
  id          String   @id @default(uuid())
  name        String
  contact     String?
  email       String   @unique
  address     String?
  
  status      String   @default("ACTIVE")
  rating      Float    @default(5.0)
  paymentTerms String?
  taxId       String?
  
  isDeleted   Boolean  @default(false)
  orders      Order[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id               String      @id @default(uuid())
  orderNumber      String      @unique
  status           String      @default("DRAFT")
  approvalStatus   String      @default("PENDING")
  
  approvedById     String?
  approvedBy       User?      @relation("OrderApprover", fields: [approvedById], references: [id])
  
  totalAmount      Float
  taxAmount        Float       @default(0.0)
  
  trackingNumber   String?
  shippingCarrier  String?
  shippedAt        DateTime?
  expectedDeliveryDate DateTime?
  
  supplierId       String
  supplier         Supplier    @relation(fields: [supplierId], references: [id])
  
  items            OrderItem[]
  goodsReceipts    GoodsReceipt[]
  
  isDeleted        Boolean     @default(false)
  
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model OrderItem {
  id               String  @id @default(uuid())
  quantity         Int
  receivedQuantity Int     @default(0)
  unitPrice        Float
  
  orderId          String
  order            Order   @relation(fields: [orderId], references: [id])
  
  productId        String
  product          Product @relation(fields: [productId], references: [id])
}

model GoodsReceipt {
  id          String   @id @default(uuid())
  grnNumber   String   @unique
  
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id])
  
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  
  items       GoodsReceiptItem[]
  
  receivedDate DateTime @default(now())
  notes       String?
}

model GoodsReceiptItem {
  id          String   @id @default(uuid())
  quantity    Int
  
  batchNumber String?
  expiryDate  DateTime?
  
  goodsReceiptId String
  goodsReceipt   GoodsReceipt @relation(fields: [goodsReceiptId], references: [id])
  
  productId     String
  product       Product      @relation(fields: [productId], references: [id])
}

model InventoryDocument {
  id          String   @id @default(uuid())
  type        String
  reference   String?
  status      String   @default("DRAFT")
  
  sourceWarehouseId String?
  sourceWarehouse   Warehouse? @relation("SourceWarehouse", fields: [sourceWarehouseId], references: [id])
  
  targetWarehouseId String?
  targetWarehouse   Warehouse? @relation("TargetWarehouse", fields: [targetWarehouseId], references: [id])
  
  items       InventoryDocumentItem[]
  
  performedBy String?
  notes       String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model InventoryDocumentItem {
  id          String   @id @default(uuid())
  quantity    Int
  
  documentId  String
  document    InventoryDocument @relation(fields: [documentId], references: [id])
  
  productId   String
  product     Product @relation(fields: [productId], references: [id])
}

model Deal {
  id            String   @id @default(uuid())
  title         String
  stage         String   @default("NEW")
  value         Float    @default(0.0)
  
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id])
  
  salesOrders   SalesOrder[]
  items         DealItem[]
  activities    Activity[]
  
  assignedToId  String?
  assignedTo    User?     @relation(fields: [assignedToId], references: [id])
  
  probability   Int       @default(10)
  expectedCloseDate DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Activity {
  id        String   @id @default(uuid())
  type      String
  subject   String
  content   String?
  
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id])
  
  createdAt DateTime @default(now())
}

model DealItem {
  id        String @id @default(uuid())
  quantity  Int
  price     Float
  
  dealId    String
  deal      Deal   @relation(fields: [dealId], references: [id])
  
  productId String
  product   Product @relation(fields: [productId], references: [id])
}

model SalesOrder {
  id            String   @id @default(uuid())
  orderNumber   String   @unique
  status        String   @default("DRAFT")
  
  dealId        String?
  deal          Deal?    @relation(fields: [dealId], references: [id])
  
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id])
  
  items         SalesOrderItem[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SalesOrderItem {
  id        String   @id @default(uuid())
  quantity  Int
  reserved  Int      @default(0)
  
  salesOrderId String
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id])
  
  productId    String
  product      Product @relation(fields: [productId], references: [id])
}

model Customer {
  id        String   @id @default(uuid())
  name      String
  email     String?
  phone     String?
  address   String?
  city      String?
  zipCode   String?
  isDeleted Boolean  @default(false)
  sales     Sale[]
  deals     Deal[]
  salesOrders SalesOrder[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Sale {
  id          String     @id @default(uuid())
  invoiceNo   String     @unique
  totalAmount Float
  taxAmount   Float
  discountAmount Float @default(0.0)
  
  isHomeDelivery      Boolean   @default(false)
  deliveryAddress     String?
  deliveryCity        String?
  estimatedDelivery   DateTime?

  team                String    @default("SALES")

  status          String    @default("PENDING")
  trackingNumber  String?
  shippingCarrier String?
  shippedAt       DateTime?

  customerId  String?
  customer    Customer?  @relation(fields: [customerId], references: [id])
  
  items       SaleItem[]
  isDeleted   Boolean    @default(false)
  payment     Payment?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model SaleItem {
  id        String  @id @default(uuid())
  quantity  Int
  unitPrice Float
  
  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id])
  
  productId String
  product   Product @relation(fields: [productId], references: [id])
}

model Payment {
  id            String        @id @default(uuid())
  amount        Float
  method        String        @default("CASH")
  type          String        @default("RECEIVABLE")
  transactionId String?       @unique
  
  saleId        String?       @unique
  sale          Sale?         @relation(fields: [saleId], references: [id])
  
  createdAt     DateTime      @default(now())
}

model Ledger {
  id          String   @id @default(uuid())
  title       String
  type        String
  amount      Float
  category    String   @default("GENERAL")
  description String?
  createdAt   DateTime @default(now())
}

model Department {
  id          String     @id @default(uuid())
  name        String     @unique
  employees   Employee[]
  isDeleted   Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Employee {
  id            String     @id @default(uuid())
  userId        String?    @unique
  user          User?      @relation(fields: [userId], references: [id])
  
  employeeId    String     @unique
  firstName     String
  lastName      String
  designation   String
  joiningDate   DateTime
  salary        Float
  performanceRating Int?
  incentivePercentage Float @default(0.0)
  
  departmentId  String
  department    Department @relation(fields: [departmentId], references: [id])
  
  attendances   Attendance[]
  payrolls      Payroll[]
  isDeleted     Boolean    @default(false)
  
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model PricingRule {
  id          String   @id @default(uuid())
  name        String
  minQuantity Int
  discountPercent Float
  
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Attendance {
  id          String   @id @default(uuid())
  date        DateTime @default(now())
  status      String
  checkIn     DateTime?
  checkOut    DateTime?
  overtimeHours Float     @default(0.0)
  
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
}

model Payroll {
  id            String   @id @default(uuid())
  amount        Float
  incentive     Float    @default(0.0)
  overtimeAmount Float   @default(0.0)
  totalPayout   Float
  paymentDate   DateTime @default(now())
  month         String
  status        String   @default("PAID")
  
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id])
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
