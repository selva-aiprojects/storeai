// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// --- Auth & User Management ---

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  firstName     String
  lastName      String
  role          String    @default("STAFF")
  isActive      Boolean   @default(true)
  isDeleted     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  employee      Employee?
  deals         Deal[]
}

// --- Product Management ---

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id            String         @id @default(uuid())
  sku           String         @unique
  name          String
  description   String?
  price         Float
  costPrice     Float
  stockQuantity Int            @default(0)
  unit          String         @default("pcs")
  
  // Advanced Features: Intelligent Reordering
  batchNumber   String?
  expiryDate    DateTime?
  lowStockThreshold Int        @default(10)
  leadTimeDays     Int        @default(7)  // Days it takes to restock
  avgDailySales    Float      @default(0.5) // Average units sold per day
  
  categoryId    String
  category      Category       @relation(fields: [categoryId], references: [id])
  isDeleted     Boolean        @default(false)
  
  pricingRules  PricingRule[]
  orderItems    OrderItem[]
  saleItems     SaleItem[]
  stocks        Stock[]
  inventoryItems InventoryDocumentItem[]
  dealItems     DealItem[]
  salesOrderItems SalesOrderItem[]
  
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Warehouse {
  id         String   @id @default(uuid())
  name       String   @unique
  location   String
  isDefault  Boolean  @default(false)
  stocks     Stock[]
  
  // Relations to InventoryDocument
  sourceDocuments InventoryDocument[] @relation("SourceWarehouse")
  targetDocuments InventoryDocument[] @relation("TargetWarehouse")
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Stock {
  id           String    @id @default(uuid())
  quantity     Int       @default(0)
  reserved     Int       @default(0)
  
  warehouseId  String
  warehouse    Warehouse @relation(fields: [warehouseId], references: [id])
  
  productId    String
  product      Product   @relation(fields: [productId], references: [id])

  updatedAt    DateTime  @updatedAt
  
  @@unique([warehouseId, productId])
}

// --- Order Management (Purchases from Suppliers) ---

model Supplier {
  id        String   @id @default(uuid())
  name      String
  contact   String?
  email     String   @unique
  address   String?
  isBlocked Boolean  @default(false) // Advanced: Supplier Blocking
  isDeleted Boolean  @default(false)
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id          String      @id @default(uuid())
  orderNumber String      @unique
  status      String      @default("PENDING") // PENDING, SHIPPED, RECEIVED, CANCELLED
  totalAmount Float
  
  // Shipment Tracking (Inbound)
  trackingNumber  String?
  shippingCarrier String?
  shippedAt       DateTime?
  expectedDeliveryDate DateTime?
  
  supplierId  String
  supplier    Supplier    @relation(fields: [supplierId], references: [id])
  
  items       OrderItem[]
  isDeleted   Boolean     @default(false)
  payment     Payment?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model OrderItem {
  id        String  @id @default(uuid())
  quantity  Int
  unitPrice Float
  
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  
  productId String
  product   Product @relation(fields: [productId], references: [id])
}

// --- Inventory Documents (Receipts, Transfers, Adjustments) ---

model InventoryDocument {
  id          String   @id @default(uuid())
  type        String   // RECEIPT, TRANSFER, ADJUSTMENT, WRITE_OFF, DELIVERY_NOTE
  reference   String?  // Linked Order ID or formatted REF
  status      String   @default("DRAFT") // DRAFT, POSTED, CANCELLED
  
  sourceWarehouseId String?
  sourceWarehouse   Warehouse? @relation("SourceWarehouse", fields: [sourceWarehouseId], references: [id])
  
  targetWarehouseId String? // If transfer
  targetWarehouse   Warehouse? @relation("TargetWarehouse", fields: [targetWarehouseId], references: [id])
  
  items       InventoryDocumentItem[]
  
  performedBy String?
  notes       String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model InventoryDocumentItem {
  id          String   @id @default(uuid())
  quantity    Int
  
  documentId  String
  document    InventoryDocument @relation(fields: [documentId], references: [id])
  
  productId   String
  product     Product @relation(fields: [productId], references: [id])
}

// --- CRM & Sales Orders ---

model Deal {
  id            String   @id @default(uuid())
  title         String
  stage         String   @default("NEW") // NEW, QUALIFIED, NEGOTIATION, WON, LOST
  value         Float    @default(0.0)
  
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id])
  
  salesOrders   SalesOrder[]
  items         DealItem[]
  activities    Activity[]
  
  assignedToId  String?
  assignedTo    User?     @relation(fields: [assignedToId], references: [id])
  
  probability   Int       @default(10) // 10%, 50%, 90%
  expectedCloseDate DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Activity {
  id        String   @id @default(uuid())
  type      String   // CALL, EMAIL, MEETING, NOTE
  subject   String
  content   String?
  
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id])
  
  createdAt DateTime @default(now())
}

model DealItem {
  id        String @id @default(uuid())
  quantity  Int
  price     Float
  
  dealId    String
  deal      Deal   @relation(fields: [dealId], references: [id])
  
  productId String
  product   Product @relation(fields: [productId], references: [id])
}

model SalesOrder {
  id            String   @id @default(uuid())
  orderNumber   String   @unique
  status        String   @default("DRAFT") // DRAFT, RESERVED, CONFIRMED, COMPLETED, CANCELLED
  
  dealId        String?
  deal          Deal?    @relation(fields: [dealId], references: [id])
  
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id])
  
  items         SalesOrderItem[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SalesOrderItem {
  id        String   @id @default(uuid())
  quantity  Int
  reserved  Int      @default(0)
  
  salesOrderId String
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id])
  
  productId    String
  product      Product @relation(fields: [productId], references: [id])
}

// --- Sales Management ---

model Customer {
  id        String   @id @default(uuid())
  name      String
  email     String?
  phone     String?
  address   String?
  city      String?
  zipCode   String?
  isDeleted Boolean  @default(false)
  sales     Sale[]
  deals     Deal[]
  salesOrders SalesOrder[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Sale {
  id          String     @id @default(uuid())
  invoiceNo   String     @unique
  totalAmount Float
  taxAmount   Float
  discountAmount Float @default(0.0)
  
  // Home Delivery Management
  isHomeDelivery      Boolean   @default(false)
  deliveryAddress     String?
  deliveryCity        String?
  estimatedDelivery   DateTime?

  // Team Assignment
  team                String    @default("SALES") // SALES, OPERATIONS, MANAGEMENT, SHIPMENT, OTHERS

  // Shipment Tracking (Outbound)
  status          String    @default("PENDING") // PENDING, SHIPPED, DELIVERED
  trackingNumber  String?
  shippingCarrier String?
  shippedAt       DateTime?

  customerId  String?
  customer    Customer?  @relation(fields: [customerId], references: [id])
  
  items       SaleItem[]
  isDeleted   Boolean    @default(false)
  payment     Payment?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model SaleItem {
  id        String  @id @default(uuid())
  quantity  Int
  unitPrice Float
  
  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id])
  
  productId String
  product   Product @relation(fields: [productId], references: [id])
}

// --- Account Management ---

model Payment {
  id            String        @id @default(uuid())
  amount        Float
  method        String        @default("CASH") // CASH, CARD, TRANSFER
  type          String        @default("RECEIVABLE") // RECEIVABLE (from customer), PAYABLE (to supplier)
  transactionId String?       @unique
  
  saleId        String?       @unique
  sale          Sale?         @relation(fields: [saleId], references: [id])
  
  orderId       String?       @unique
  order         Order?        @relation(fields: [orderId], references: [id])
  
  createdAt     DateTime      @default(now())
}

model Ledger {
  id          String   @id @default(uuid())
  title       String
  type        String   // DEBIT / CREDIT
  amount      Float
  category    String   @default("GENERAL") // PAYABLE, RECEIVABLE, OPERATIONAL
  description String?
  createdAt   DateTime @default(now())
}

// --- HR Management ---

model Department {
  id          String     @id @default(uuid())
  name        String     @unique
  employees   Employee[]
  isDeleted   Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Employee {
  id            String     @id @default(uuid())
  userId        String?    @unique
  user          User?      @relation(fields: [userId], references: [id])
  
  employeeId    String     @unique
  firstName     String
  lastName      String
  designation   String
  joiningDate   DateTime
  salary        Float
  performanceRating Int?   // 1-5 rating
  incentivePercentage Float @default(0.0) // Sales Commission %
  
  departmentId  String
  department    Department @relation(fields: [departmentId], references: [id])
  
  attendances   Attendance[]
  payrolls      Payroll[]
  isDeleted     Boolean    @default(false)
  
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model PricingRule {
  id          String   @id @default(uuid())
  name        String
  minQuantity Int
  discountPercent Float
  
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Attendance {
  id          String   @id @default(uuid())
  date        DateTime @default(now())
  status      String   // PRESENT, ABSENT, LEAVE
  checkIn     DateTime?
  checkOut    DateTime?
  overtimeHours Float     @default(0.0)
  
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
}

model Payroll {
  id            String   @id @default(uuid())
  amount        Float    // Base Salary
  incentive     Float    @default(0.0)
  overtimeAmount Float   @default(0.0)
  totalPayout   Float    // Base + Incentive + OT
  paymentDate   DateTime @default(now())
  month         String   // e.g., "January 2026"
  status        String   @default("PAID") // PENDING, PAID
  
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id])
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
